{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Renovate configuration for Tekton task updates",
  "extends": [
    "config:recommended",
    ":gitSignOff"
  ],
  "platformCommit": "enabled",
  "branchPrefix": "konflux/renovate/",
  "prConcurrentLimit": 5,
  
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [
        "nodejs-devfile-sample-multiarch-pull-request.yaml",
        "nodejs-devfile-sample-multiarch-push.yaml"
      ],
      "matchStrings": [
        "value:\\s+(?<depName>quay\\.io/(?:konflux-ci/tekton-catalog|redhat-appstudio-tekton-catalog)/[^:]+):(?<currentValue>[^@\\s]+)(@(?<currentDigest>sha256:[a-f0-9]+))?"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker",
      "extractVersionTemplate": "{{#if currentDigest}}{{currentValue}}@{{currentDigest}}{{else}}{{currentValue}}{{/if}}",
      "depTypeTemplate": "tekton-task"
    }
  ],
  
  "packageRules": [
    {
      "description": "Group all Konflux task updates together",
      "matchDatasources": ["docker"],
      "matchDepTypes": ["tekton-task"],
      "matchPackageNames": [
        "/^quay.io/konflux-ci/tekton-catalog//",
        "/^quay.io/redhat-appstudio-tekton-catalog//"
      ],
      "groupName": "Konflux task references",
      "groupSlug": "konflux-tasks",
      "branchTopic": "konflux-tasks-upgrade",
      "commitMessageTopic": "Konflux task references",
      "prCreation": "immediate",
      "automerge": false,
      "ignoreTests": true,
      "prBodyColumns": [
        "Package",
        "Change",
        "Notes"
      ],
      "prBodyNotes": [
        "{{#if (or (eq updateType 'minor') (eq updateType 'major'))}}:warning: Check migration guide for breaking changes :warning:{{/if}}"
      ],
      "recreateWhen": "always",
      "recreateClosed": true,
      "rebaseWhen": "behind-base-branch",
      "pinDigests": true
    }
  ],
  
  "dependencyDashboard": true,
  "dependencyDashboardAutoclose": true,
  "branchConcurrentLimit": 1,
  "prHourlyLimit": 0
}
